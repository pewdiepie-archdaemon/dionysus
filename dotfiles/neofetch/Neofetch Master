#!/bin/bash


!/bin/bash

ascii_col=2
text_col=50
ascii_row=1
delay=0.05

# Print the system info once (right side)
tput cup $ascii_row $text_col
neofetch --disable ascii

# Animate the left side without clearing the screen
while true; do
  tput cup $ascii_row $ascii_col
  awk '{printf "%-45s\n", $0}' ~/reactor.txt
  sleep $delay
done





