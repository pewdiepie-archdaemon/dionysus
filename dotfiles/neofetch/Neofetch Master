# Capture Neofetch output once without ASCII

# Define position (row and col) to draw ASCII art
ascii_row=1
ascii_col=2
delay=0.05

while true; do
  clear

  # Position for ASCII (where distro art usually goes)
  tput cup $ascii_row $ascii_col
  cat ~/reactor.txt

  # Position for Neofetch info (right side, adjust padding)
  tput cup $ascii_row 40
  cat /tmp/neoinfo.txt

  sleep $delay
done
